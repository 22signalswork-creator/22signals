# Supabase credentials — required for live CMS content, admin auth, and forms.
# In local dev: copy this file to `.env` and fill in the values.
# On Vercel: add these as Environment Variables in Project Settings.
# Note: Vite only exposes vars prefixed with VITE_ to the client bundle.

VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
